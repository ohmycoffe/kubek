# Where should we write the GIF?
Output docs/assets/demo.gif

Set FontSize 16
Set Width 800
Set Height 450
Set WindowBar Colorful

Hide
Type "clear"
Enter
Sleep 200ms
Show

Type "kubepf"
Sleep 500ms
Enter
Sleep 3s

# Namespace selection — type to filter, then confirm
Type "dem"
Sleep 500ms
Enter
Sleep 2s

# Service checkbox — select nginx (first item)
Space
Sleep 400ms

# Move to httpd and select it
Down
Sleep 400ms
Space
Sleep 400ms

# Confirm selection
Enter
Sleep 3s

Ctrl+C
Sleep 1s
