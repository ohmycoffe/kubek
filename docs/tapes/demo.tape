Output docs/assets/demo.gif

Set Theme "Catppuccin Mocha"
Set FontSize 16
Set Width 650
Set Height 500
Set WindowBar Colorful
Set TypingSpeed 80ms
Set CursorBlink false
Set Padding 20

Hide
Type "clear"
Enter
Sleep 300ms
Show

# --- envx service ---
Type "envx service"
Enter
Sleep 3s

Type "demo"
Sleep 300ms
Enter
Sleep 2s

Enter
Sleep 4s

# --- envx worker ---
Type "clear"
Enter
Sleep 300ms

Type "envx worker"
Enter
Sleep 3s

Type "demo"
Sleep 300ms
Enter
Sleep 2s

Enter
Sleep 4s

Sleep 2s
