[
  {
    "kind": "WorkflowTemplate",
    "metadata": {
      "name": "data-processor",
      "namespace": "ns-kubectl-export-dotenv"
    },
    "spec": {
      "templates": [
        {
          "container": {
            "env": [
              {
                "name": "BATCH_SIZE",
                "value": "{{inputs.parameters.batch_size}}"
              },
              {
                "name": "SOURCE_BUCKET",
                "value": "{{inputs.parameters.source_bucket}}"
              },
              {
                "name": "DB_HOST",
                "value_from": {
                  "config_map_key_ref": {
                    "key": "DATABASE_HOST",
                    "name": "app-config"
                  }
                }
              },
              {
                "name": "API_KEY",
                "value_from": {
                  "secret_key_ref": {
                    "key": "API_KEY",
                    "name": "app-secrets"
                  }
                }
              }
            ],
            "env_from": [
              {
                "config_map_ref": {
                  "name": "app-config"
                }
              },
              {
                "secret_ref": {
                  "name": "app-secrets"
                }
              }
            ]
          },
          "inputs": {
            "parameters": [
              {
                "default": "100",
                "name": "batch_size"
              },
              {
                "default": "my-bucket",
                "name": "source_bucket"
              }
            ]
          },
          "name": "main"
        }
      ]
    }
  },
  {
    "kind": "WorkflowTemplate",
    "metadata": {
      "name": "dummy-worker",
      "namespace": "ns-kubectl-export-dotenv"
    },
    "spec": {
      "templates": [
        {
          "container": {
            "env": [
              {
                "name": "DIRECT_VALUE",
                "value": "hello-from-dummy-worker"
              }
            ]
          },
          "name": "main"
        }
      ]
    }
  }
]
